from ultralytics import YOLO
from ultralytics.data.augment import RandomPerspective, RandomFlip, RandomHSV

model = YOLO("yolov8n.pt")

custom_trasforms = [
    RandomFlip(p=0.35, direction="horizontal"),
    RandomFlip(p=0.35, direction="vertical"),
    RandomPerspective(degrees=80.0, translate=0.3, scale=0.5, shear=90.0, perspective=0.1),
    RandomHSV(hgain=0.5, sgain=0.5, vgain=0.5)
]
                     
results = model.train(data="fire_yolo/data.yaml", epochs=300)

results = model.val()
